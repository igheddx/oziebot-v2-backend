# Copy to .env at repo root for docker-compose; adjust per service in override files as needed.

# PostgreSQL
POSTGRES_USER=oziebot
POSTGRES_PASSWORD=oziebot
POSTGRES_DB=oziebot
DATABASE_URL=postgresql+psycopg://oziebot:oziebot@postgres:5432/oziebot

# Redis (queues + cache)
REDIS_URL=redis://redis:6379/0

# API
OZIEBOT_API_SECRET=change-me-in-production
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ACCESS_EXP_MINUTES=15
JWT_REFRESH_EXP_DAYS=7
CORS_ORIGINS=http://localhost:3000

# Seed root admin: python -m oziebot_api.scripts.seed_root_admin (requires DATABASE_URL)
SEED_ROOT_EMAIL=root@localhost
SEED_ROOT_PASSWORD=

# Optional: seed_platform_catalog Stripe placeholders
SEED_STRIPE_PRICE_ID_ALL=
SEED_STRIPE_PRICE_ID_EACH=
SEED_STRIPE_PRODUCT_ID_ALL=
SEED_STRIPE_PRODUCT_ID_EACH=

# Stripe (optional; webhooks verified in api)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/billing/cancel

# Coinbase (optional; referenced by execution-engine)
COINBASE_API_KEY_ID=
COINBASE_API_SECRET=

# API: Fernet key for encrypting exchange credentials at rest (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
EXCHANGE_CREDENTIALS_ENCRYPTION_KEY=
# Coinbase Advanced Trade REST base (CDP JWT)
COINBASE_API_BASE_URL=https://api.coinbase.com

# Alerts (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# Demo: strategy-engine emits one sample intent on startup
OZIEBOT_STRATEGY_DEMO=0

# paper | live — demo intent uses this mode and mode-specific Redis queues
OZIEBOT_TRADING_MODE=paper
