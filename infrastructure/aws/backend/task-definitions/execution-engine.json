{
  "family": "oziebot-execution-engine",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "${ECS_EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${ECS_TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "execution-engine",
      "image": "IMAGE_URI",
      "essential": true,
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "REDIS_URL", "value": "${REDIS_URL}" },
        { "name": "OBSERVABILITY_S3_BUCKET", "value": "${OBSERVABILITY_S3_BUCKET}" },
        { "name": "OBSERVABILITY_S3_PREFIX", "value": "${OBSERVABILITY_S3_PREFIX}" },
        { "name": "OBSERVABILITY_S3_REGION", "value": "${OBSERVABILITY_S3_REGION}" },
        { "name": "OZIEBOT_HEALTH_PORT", "value": "8080" },
        { "name": "OZIEBOT_HEALTH_STALE_SECONDS", "value": "300" },
        { "name": "OZIEBOT_HEALTH_AUTO_TOUCH_SECONDS", "value": "30" },
        { "name": "COINBASE_API_BASE_URL", "value": "https://api.coinbase.com" },
        { "name": "PAPER_DEFAULT_FEE_BPS", "value": "15" },
        { "name": "PAPER_DEFAULT_SLIPPAGE_BPS", "value": "8" },
        { "name": "RECONCILIATION_INTERVAL_SECONDS", "value": "60" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "${DATABASE_URL_SECRET_ARN}" },
        { "name": "EXCHANGE_CREDENTIALS_ENCRYPTION_KEY", "valueFrom": "${EXCHANGE_CREDENTIALS_ENCRYPTION_KEY_SECRET_ARN}" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/oziebot-prod/execution-engine",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8080/health')\" || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 120
      }
    }
  ]
}
