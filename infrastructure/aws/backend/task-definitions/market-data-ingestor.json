{
  "family": "oziebot-market-data-ingestor",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "${ECS_EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${ECS_TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "market-data-ingestor",
      "image": "IMAGE_URI",
      "essential": true,
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "REDIS_URL", "value": "${REDIS_URL}" },
        { "name": "OZIEBOT_HEALTH_PORT", "value": "8080" },
        { "name": "OZIEBOT_HEALTH_STALE_SECONDS", "value": "300" },
        { "name": "OZIEBOT_HEALTH_AUTO_TOUCH_SECONDS", "value": "30" },
        { "name": "COINBASE_WS_URL", "value": "wss://advanced-trade-ws.coinbase.com" },
        { "name": "COINBASE_REST_URL", "value": "https://api.exchange.coinbase.com" },
        { "name": "CANDLES_GRANULARITY_SEC", "value": "60" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "${DATABASE_URL_SECRET_ARN}" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/oziebot-prod/market-data-ingestor",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8080/health')\" || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 180
      }
    }
  ]
}
